        <div class="divider"></div>
        
        <div class="menu-section">
            <h3><i class="fas fa-tools"></i> Herramientas</h3>
            <ul class="menu-items">
                <li><a href="#" class="menu-item"><i class="fas fa-search"></i> Verificador de Noticias</a></li>
