        </div>
        
        <div class="divider"></div>
        
        <div class="menu-section">
            <h3><i class="fas fa-book"></i> Módulos de Aprendizaje</h3>
            <ul class="menu-items">
                <li><a href="#" class="menu-item"><i class="fas fa-star"></i> Módulo 1: Ciudadanía Digital</a></li>
